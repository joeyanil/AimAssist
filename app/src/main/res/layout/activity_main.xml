<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1a1a2e"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AimAssist Pro"
        android:textSize="28sp"
        android:textColor="#00d4ff"
        android:gravity="center"
        android:padding="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Headshot Aim Assist"
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:padding="8dp"/>

    <Switch
        android:id="@+id/switchAimAssist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aim Assist OFF"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:layout_margin="16dp"/>

    <TextView
        android:id="@+id/textview4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sensitivity: 0.5"
        android:textSize="14sp"
        android:textColor="#ffffff"
        android:gravity="center"
        android:padding="8dp"/>

    <SeekBar
        android:id="@+id/seekBarSensitivity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="10"
        android:progress="5"
        android:padding="16dp"/>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="START AIM ASSIST"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:background="#00d4ff"
        android:padding="16dp"
        android:layout_marginTop="24dp"/>

</LinearLayout>
